FROM debian:trixie-slim

RUN apt-get update && apt-get install -y ca-certificates openssh-client curl && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 session-manager && \
    useradd --uid 1000 --gid session-manager --create-home session-manager

COPY artifact/session-manager /usr/local/bin/session-manager
RUN chmod +x /usr/local/bin/session-manager

EXPOSE 8000

USER session-manager

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["session-manager"]
